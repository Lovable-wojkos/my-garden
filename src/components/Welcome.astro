---
import Topbar from "@/components/Topbar.astro";
import { pl } from "@/lib/copy/pl";
---

<div class="bg-background min-h-screen w-full">
  <div class="relative z-10 p-4 sm:p-8">
    <Topbar />

    <div class="mx-auto flex max-w-4xl flex-col items-center justify-center px-4 py-16 text-center sm:py-24 lg:py-32">
      <p class="text-primary mb-3 text-sm font-medium tracking-wide uppercase">{pl.appName}</p>
      <h1 class="text-foreground mb-6 text-4xl leading-tight font-bold sm:text-5xl lg:text-6xl">
        {pl.landing.headline}
      </h1>
      <p class="text-muted-foreground mb-10 max-w-2xl text-lg sm:text-xl">
        {pl.landing.subhead}
      </p>
      <div class="flex flex-col gap-4 sm:flex-row">
        <a
          href="/auth/signin"
          class="bg-primary text-primary-foreground hover:bg-primary/90 inline-flex min-h-11 items-center justify-center rounded-lg px-6 py-3 text-base font-medium transition-colors"
        >
          {pl.landing.ctaSignIn}
        </a>
      </div>
    </div>

    <div class="mx-auto grid max-w-4xl grid-cols-1 gap-6 px-4 pb-24 sm:grid-cols-3">
      <div class="border-border bg-card rounded-xl border p-6 shadow-sm">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-primary mb-4"
        >
          <path d="M12 22v-7"></path>
          <path d="M8 22v-2"></path>
          <path d="M16 22v-2"></path>
          <path d="M4 10V4a2 2 0 0 1 2-2h12a2 2 0 0 1 2 2v6"></path>
          <path d="M2 10h20"></path>
          <path d="M7 15h10"></path>
        </svg>
        <h3 class="text-foreground mb-2 text-lg font-semibold">{pl.landing.featureFieldsTitle}</h3>
        <p class="text-muted-foreground text-sm leading-relaxed">
          {pl.landing.featureFieldsDesc}
        </p>
      </div>

      <div class="border-border bg-card rounded-xl border p-6 shadow-sm">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-primary mb-4"
        >
          <path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"></path>
        </svg>
        <h3 class="text-foreground mb-2 text-lg font-semibold">{pl.landing.featureWeatherTitle}</h3>
        <p class="text-muted-foreground text-sm leading-relaxed">
          {pl.landing.featureWeatherDesc}
        </p>
      </div>

      <div class="border-border bg-card rounded-xl border p-6 shadow-sm">
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="text-primary mb-4"
        >
          <path d="M12 2v6"></path>
          <path d="m4.93 10.93 4.24 4.24"></path>
          <path d="M2 18h6"></path>
          <path d="M20 18h-6"></path>
          <path d="m19.07 10.93-4.24 4.24"></path>
          <path d="M12 22v-6"></path>
        </svg>
        <h3 class="text-foreground mb-2 text-lg font-semibold">{pl.landing.featurePlantingTitle}</h3>
        <p class="text-muted-foreground text-sm leading-relaxed">
          {pl.landing.featurePlantingDesc}
        </p>
      </div>
    </div>
  </div>
</div>
