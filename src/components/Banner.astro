---
import { cn } from "@/lib/utils";

type Variant = "info" | "warning" | "error";

interface Props {
  variant?: Variant;
}

const { variant = "info" } = Astro.props;

const variantClass: Record<Variant, string> = {
  info: "bg-muted text-foreground border-border",
  warning: "bg-accent/20 text-accent-foreground border-accent/40",
  error: "border-destructive/30 bg-destructive/10 text-destructive",
};
---

<div
  class={cn("border-b px-4 py-3 text-center text-sm", variantClass[variant])}
  role={variant === "error" ? "alert" : "status"}
>
  <slot />
</div>
