---
import { pl } from "@/lib/copy/pl";
import { cn } from "@/lib/utils";

interface Props {
  title: string;
  activeNav: "dashboard" | "catalog" | "settings" | "admin";
}

const { title, activeNav } = Astro.props;
const { user } = Astro.locals;
const isAdmin = user?.app_metadata.role === "admin";

type NavId = Props["activeNav"];

const baseNavItems: { id: NavId; href: string; label: string }[] = [
  { id: "dashboard", href: "/dashboard", label: pl.nav.dashboard },
  { id: "catalog", href: "/dashboard/catalog", label: pl.nav.catalog },
  { id: "settings", href: "/dashboard/settings", label: pl.nav.settings },
];

const navItems = isAdmin
  ? [...baseNavItems, { id: "admin" as const, href: "/admin/plant-requests", label: pl.nav.admin }]
  : baseNavItems;

function navLinkClass(id: NavId, layout: "header" | "bottom") {
  const active = activeNav === id;
  return cn(
    layout === "header"
      ? "rounded-lg px-3 py-2 text-sm transition-colors min-h-11 inline-flex items-center"
      : "flex min-h-11 min-w-11 flex-1 flex-col items-center justify-center gap-0.5 px-2 py-2 text-xs transition-colors",
    active ? "text-primary font-medium" : "text-muted-foreground hover:text-foreground",
  );
}
---

<div class="bg-background text-foreground flex min-h-screen flex-col">
  <header class="border-border bg-card border-b">
    <div class="mx-auto flex w-full max-w-6xl items-center justify-between gap-4 px-4 py-3">
      <div class="min-w-0">
        <p class="text-primary text-sm font-semibold">{pl.appName}</p>
        <h1 class="text-foreground truncate text-xl font-bold md:text-2xl">{title}</h1>
      </div>

      <nav class="hidden items-center gap-1 md:flex" aria-label="Główne menu">
        {
          navItems.map((item) => (
            <a
              href={item.href}
              class:list={navLinkClass(item.id, "header")}
              aria-current={activeNav === item.id ? "page" : undefined}
            >
              {item.label}
            </a>
          ))
        }
        <form method="POST" action="/api/auth/signout" class="ml-2">
          <button
            type="submit"
            class="text-muted-foreground hover:text-foreground min-h-11 rounded-lg px-3 py-2 text-sm transition-colors"
          >
            {pl.nav.signOut}
          </button>
        </form>
      </nav>
    </div>
  </header>

  <main class="mx-auto w-full max-w-6xl flex-1 px-4 py-6 pb-24 md:pb-6">
    <slot />
  </main>

  <nav class="border-border bg-card fixed right-0 bottom-0 left-0 z-50 border-t md:hidden" aria-label="Nawigacja dolna">
    <div class="mx-auto flex max-w-6xl">
      {
        navItems.map((item) => (
          <a
            href={item.href}
            class:list={navLinkClass(item.id, "bottom")}
            aria-current={activeNav === item.id ? "page" : undefined}
          >
            {item.id === "dashboard" && (
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <rect width="7" height="9" x="3" y="3" rx="1" />
                <rect width="7" height="5" x="14" y="3" rx="1" />
                <rect width="7" height="9" x="14" y="12" rx="1" />
                <rect width="7" height="5" x="3" y="16" rx="1" />
              </svg>
            )}
            {item.id === "catalog" && (
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M12 7.5a4.5 4.5 0 1 1 4.5 4.5M12 7.5A4.5 4.5 0 1 0 7.5 12M12 7.5V9m-4.5 3a4.5 4.5 0 1 0 4.5 4.5M7.5 12H9m7.5 0a4.5 4.5 0 1 1-4.5 4.5m4.5-4.5H15m-3 4.5V15" />
                <circle cx="12" cy="12" r="3" />
              </svg>
            )}
            {item.id === "settings" && (
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M12.22 2h-.44a2 2 0 0 0-2 2v.18a2 2 0 0 1-1 1.73l-.43.25a2 2 0 0 1-2 0l-.15-.08a2 2 0 0 0-2.73.73l-.22.38a2 2 0 0 0 .73 2.73l.15.1a2 2 0 0 1 1 1.72v.51a2 2 0 0 1-1 1.74l-.15.09a2 2 0 0 0-.73 2.73l.22.38a2 2 0 0 0 2.73.73l.15-.08a2 2 0 0 1 2 0l.43.25a2 2 0 0 1 1 1.73V20a2 2 0 0 0 2 2h.44a2 2 0 0 0 2-2v-.18a2 2 0 0 1 1-1.73l.43-.25a2 2 0 0 1 2 0l.15.08a2 2 0 0 0 2.73-.73l.22-.39a2 2 0 0 0-.73-2.73l-.15-.08a2 2 0 0 1-1-1.74v-.5a2 2 0 0 1 1-1.74l.15-.09a2 2 0 0 0 .73-2.73l-.22-.38a2 2 0 0 0-2.73-.73l-.15.08a2 2 0 0 1-2 0l-.43-.25a2 2 0 0 1-1-1.73V4a2 2 0 0 0-2-2z" />
                <circle cx="12" cy="12" r="3" />
              </svg>
            )}
            {item.id === "admin" && (
              <svg
                xmlns="http://www.w3.org/2000/svg"
                width="20"
                height="20"
                viewBox="0 0 24 24"
                fill="none"
                stroke="currentColor"
                stroke-width="2"
                stroke-linecap="round"
                stroke-linejoin="round"
                aria-hidden="true"
              >
                <path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z" />
              </svg>
            )}
            <span>{item.label}</span>
          </a>
        ))
      }
    </div>
  </nav>
</div>
