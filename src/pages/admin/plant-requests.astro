---
export const prerender = false;

import AdminPlantRequestList from "@/components/plants/AdminPlantRequestList";
import AppShell from "@/components/AppShell.astro";
import Layout from "@/layouts/Layout.astro";
import { pl } from "@/lib/copy/pl";
import { getPendingPlants } from "@/lib/services/plants";
import { createServiceRoleClient } from "@/lib/supabase";
import type { PlantRow } from "@/types";

if (Astro.locals.user?.app_metadata.role !== "admin") {
  return Astro.redirect("/dashboard");
}

let plants: PlantRow[] = [];

const serviceClient = createServiceRoleClient();
if (serviceClient) {
  const { data } = await getPendingPlants(serviceClient);
  plants = data ?? [];
}
---

<Layout title={pl.admin.title}>
  <AppShell title={pl.admin.title} activeNav="admin">
    <div class="mx-auto max-w-3xl space-y-6">
      <p class="text-muted-foreground text-sm">{pl.admin.subtitle}</p>
      <AdminPlantRequestList client:load initialPlants={plants} />
    </div>
  </AppShell>
</Layout>
