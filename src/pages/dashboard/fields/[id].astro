---
export const prerender = false;

import Layout from "@/layouts/Layout.astro";
import { createClient } from "@/lib/supabase";
import { getFieldById } from "@/lib/services/fields";
import { getPlantingsByField } from "@/lib/services/plantings";
import { getPlants } from "@/lib/services/plants";
import { getUserPreferences } from "@/lib/services/user-preferences";
import FieldGrid from "@/components/fields/FieldGrid";
import WeatherWidget from "@/components/WeatherWidget";

const { id } = Astro.params;

const supabase = createClient(Astro.request.headers, Astro.cookies);

if (!supabase) {
  throw new Error("Database not configured");
}

if (!id) {
  return Astro.redirect("/dashboard");
}

const { user } = Astro.locals;
if (!user) {
  return Astro.redirect("/auth/signin");
}

const [{ data: field, error: fieldError }, { data: plantings }, { data: plants }, { data: userPrefs }] =
  await Promise.all([
    getFieldById(supabase, id),
    getPlantingsByField(supabase, id),
    getPlants(supabase),
    getUserPreferences(supabase, user.id),
  ]);

if (fieldError) {
  throw new Error("Failed to load field");
}

const initialCity = userPrefs
  ? { cityName: userPrefs.city_name, latitude: userPrefs.latitude, longitude: userPrefs.longitude }
  : null;
---

<Layout title={field.name}>
  <div class="bg-cosmic min-h-screen p-4">
    <div class="mx-auto max-w-6xl">
      <div class="mb-6 flex items-center justify-between">
        <div>
          <h1 class="bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-3xl font-bold text-transparent">
            {field.name}
          </h1>
          <p class="mt-1 text-sm text-blue-100/60">
            {field.rows} rows × {field.cols} columns
          </p>
        </div>
        <a
          href="/dashboard"
          class="rounded-lg border border-white/20 bg-white/10 px-4 py-2 text-sm text-white transition-colors hover:bg-white/20"
        >
          ← Back to Dashboard
        </a>
      </div>

      <div class="grid grid-cols-1 gap-6 lg:grid-cols-[1fr_auto]">
        <div class="rounded-2xl border border-white/10 bg-white/5 p-6 backdrop-blur-xl">
          <FieldGrid client:load field={field} plantings={plantings ?? []} plants={plants ?? []} />
        </div>

        <div class="flex items-start justify-center lg:justify-start">
          <WeatherWidget client:load initialCity={initialCity} />
        </div>
      </div>
    </div>
  </div>
</Layout>
