---
export const prerender = false;

import AppShell from "@/components/AppShell.astro";
import Layout from "@/layouts/Layout.astro";
import { createClient } from "@/lib/supabase";
import { getFieldById } from "@/lib/services/fields";
import { getPlantingsByField } from "@/lib/services/plantings";
import { getPlants } from "@/lib/services/plants";
import { getUserPreferences } from "@/lib/services/user-preferences";
import FieldGrid from "@/components/fields/FieldGrid";
import WeatherWidget from "@/components/WeatherWidget";
import { pl } from "@/lib/copy/pl";

const { id } = Astro.params;

const supabase = createClient(Astro.request.headers, Astro.cookies);

if (!supabase) {
  throw new Error("Database not configured");
}

if (!id) {
  return Astro.redirect("/dashboard");
}

const { user } = Astro.locals;
if (!user) {
  return Astro.redirect("/auth/signin");
}

const [{ data: field, error: fieldError }, { data: plantings }, { data: plants }, { data: userPrefs }] =
  await Promise.all([
    getFieldById(supabase, id),
    getPlantingsByField(supabase, id),
    getPlants(supabase),
    getUserPreferences(supabase, user.id),
  ]);

if (fieldError) {
  throw new Error("Failed to load field");
}

const initialCity = userPrefs
  ? { cityName: userPrefs.city_name, latitude: userPrefs.latitude, longitude: userPrefs.longitude }
  : null;
---

<Layout title={pl.fields.detailTitle(field.name)}>
  <AppShell title={field.name} activeNav="dashboard">
    <p class="text-muted-foreground mb-6 text-sm">
      {pl.dashboard.rowsCols(field.rows, field.cols)}
    </p>

    <div class="grid grid-cols-1 gap-6 lg:grid-cols-[1fr_auto]">
      <div class="border-border bg-card rounded-xl border p-4 shadow-sm md:p-6">
        <FieldGrid client:load field={field} plantings={plantings ?? []} plants={plants ?? []} />
      </div>

      <div class="flex items-start justify-center lg:justify-start">
        <WeatherWidget client:load initialCity={initialCity} editable={false} />
      </div>
    </div>
  </AppShell>
</Layout>
