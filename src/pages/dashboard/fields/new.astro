---
export const prerender = false;

import AppShell from "@/components/AppShell.astro";
import Layout from "@/layouts/Layout.astro";
import CreateFieldForm from "@/components/fields/CreateFieldForm";
import { pl } from "@/lib/copy/pl";
import { createClient } from "@/lib/supabase";
import { getUserPreferences } from "@/lib/services/user-preferences";

const supabase = createClient(Astro.request.headers, Astro.cookies);

if (!supabase) {
  throw new Error("Database not configured");
}

const { user } = Astro.locals;
if (!user) {
  return Astro.redirect("/auth/signin");
}

const { data: prefs, error: prefsError } = await getUserPreferences(supabase, user.id);

if (prefsError) {
  throw new Error("Failed to load user preferences");
}

if (!prefs?.region_id) {
  return Astro.redirect("/dashboard/settings");
}
---

<Layout title={pl.fields.newTitle}>
  <AppShell title={pl.fields.newTitle} activeNav="dashboard">
    <div class="mx-auto w-full max-w-md">
      <div class="border-border bg-card rounded-xl border p-6 shadow-sm md:p-8">
        <CreateFieldForm client:load />
      </div>
    </div>
  </AppShell>
</Layout>
