---
export const prerender = false;

import Layout from "@/layouts/Layout.astro";
import CreateFieldForm from "@/components/fields/CreateFieldForm";
import { createClient } from "@/lib/supabase";
import { getUserPreferences } from "@/lib/services/user-preferences";

const supabase = createClient(Astro.request.headers, Astro.cookies);

if (!supabase) {
  throw new Error("Database not configured");
}

const { user } = Astro.locals;
if (!user) {
  return Astro.redirect("/auth/signin");
}

const { data: prefs, error: prefsError } = await getUserPreferences(supabase, user.id);

if (prefsError) {
  throw new Error("Failed to load user preferences");
}

if (!prefs?.region_id) {
  return Astro.redirect("/dashboard?location=required");
}
---

<Layout title="New Field">
  <div class="bg-cosmic flex min-h-screen items-center justify-center p-4">
    <div class="w-full max-w-md rounded-2xl border border-white/10 bg-white/10 p-8 text-white backdrop-blur-xl">
      <h1 class="mb-6 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-2xl font-bold text-transparent">
        Create a new field
      </h1>
      <CreateFieldForm client:load />
    </div>
  </div>
</Layout>
