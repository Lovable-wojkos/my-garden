---
export const prerender = false;

import Layout from "@/layouts/Layout.astro";
import CreateFieldForm from "@/components/fields/CreateFieldForm";
import { createClient } from "@/lib/supabase";
import { getRegions } from "@/lib/services/regions";

const supabase = createClient(Astro.request.headers, Astro.cookies);
const regions = supabase ? ((await getRegions(supabase)).data ?? []) : [];
---

<Layout title="New Field">
  <div class="bg-cosmic flex min-h-screen items-center justify-center p-4">
    <div class="w-full max-w-md rounded-2xl border border-white/10 bg-white/10 p-8 text-white backdrop-blur-xl">
      <h1 class="mb-6 bg-gradient-to-r from-blue-200 to-purple-200 bg-clip-text text-2xl font-bold text-transparent">
        Create a new field
      </h1>
      <CreateFieldForm client:load regions={regions} />
    </div>
  </div>
</Layout>
