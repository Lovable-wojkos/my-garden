---
import AppShell from "@/components/AppShell.astro";
import Layout from "@/layouts/Layout.astro";
import WeatherWidget from "@/components/WeatherWidget";
import { pl } from "@/lib/copy/pl";
import { createClient } from "@/lib/supabase";
import { getUserPreferences } from "@/lib/services/user-preferences";
import { getFieldsByUser } from "@/lib/services/fields";

const { user } = Astro.locals;
const supabase = createClient(Astro.request.headers, Astro.cookies);

const [{ data: prefs }, { data: fields }] =
  user && supabase
    ? await Promise.all([getUserPreferences(supabase, user.id), getFieldsByUser(supabase, user.id)])
    : [{ data: null }, { data: [] }];

const hasRegion = Boolean(prefs?.region_id);
const locationRequired = Astro.url.searchParams.get("location") === "required";
const initialCity = prefs ? { cityName: prefs.city_name, latitude: prefs.latitude, longitude: prefs.longitude } : null;
---

<Layout title={pl.dashboard.title}>
  <AppShell title={pl.dashboard.title} activeNav="dashboard">
    {
      !hasRegion ? (
        <div class="mx-auto flex max-w-md flex-col items-center gap-4 py-8 text-center">
          {locationRequired && <p class="text-destructive text-sm">{pl.dashboard.locationRequiredBeforeField}</p>}
          <div class="border-border bg-card space-y-4 rounded-xl border p-8 shadow-sm">
            <p class="text-muted-foreground text-sm">{pl.dashboard.locationNotSet}</p>
            <a
              href="/dashboard/settings"
              class="bg-primary text-primary-foreground hover:bg-primary/90 inline-flex min-h-11 items-center rounded-lg px-4 py-2 text-sm font-medium transition-colors"
            >
              {pl.dashboard.goToSettings}
            </a>
          </div>
        </div>
      ) : (
        <div class="grid grid-cols-1 gap-6 lg:grid-cols-[1fr_auto]">
          <div class="space-y-4">
            <div class="flex items-center justify-between">
              <h2 class="text-foreground text-lg font-semibold">{pl.dashboard.myFields}</h2>
              <a
                href="/dashboard/fields/new"
                class="bg-primary text-primary-foreground hover:bg-primary/90 inline-flex min-h-11 items-center rounded-lg px-3 py-2 text-sm font-medium transition-colors"
              >
                + {pl.dashboard.newField}
              </a>
            </div>

            {fields && fields.length > 0 ? (
              <ul class="space-y-2">
                {fields.map((field) => (
                  <li>
                    <a
                      href={`/dashboard/fields/${field.id}`}
                      class="border-border bg-card hover:bg-muted flex items-center justify-between rounded-xl border p-4 shadow-sm transition-colors"
                    >
                      <div>
                        <p class="text-foreground font-semibold">{field.name}</p>
                        <p class="text-muted-foreground text-sm">{pl.dashboard.rowsCols(field.rows, field.cols)}</p>
                      </div>
                      <span class="text-muted-foreground">→</span>
                    </a>
                  </li>
                ))}
              </ul>
            ) : (
              <div class="border-border bg-card text-muted-foreground rounded-xl border p-8 text-center shadow-sm">
                <p>{pl.dashboard.noFields}</p>
                <a href="/dashboard/fields/new" class="text-primary mt-2 inline-block text-sm hover:underline">
                  {pl.dashboard.createFirstField}
                </a>
              </div>
            )}
          </div>

          <div class="flex items-start justify-center lg:justify-start">
            <WeatherWidget initialCity={initialCity} editable={false} client:load />
          </div>
        </div>
      )
    }
  </AppShell>
</Layout>
