---
import AppShell from "@/components/AppShell.astro";
import Layout from "@/layouts/Layout.astro";
import WeatherWidget from "@/components/WeatherWidget";
import FieldListItem from "@/components/dashboard/FieldListItem";
import { pl } from "@/lib/copy/pl";
import { createClient } from "@/lib/supabase";
import { getUserPreferences } from "@/lib/services/user-preferences";
import { getFieldsByUser } from "@/lib/services/fields";
import { getPlantingsByUser } from "@/lib/services/plantings";
import { getPlants } from "@/lib/services/plants";
import { getRainfall7dCalendarMm } from "@/lib/services/weather";
import { getWateringEventsInWindow, aggregateWateringEventsMm, sumAllWateringEventsMm } from "@/lib/services/watering-events";
import { aggregateFieldWatering, evaluatePlantingWatering, type WateringStatus } from "@/lib/watering";
import WaterButton from "@/components/dashboard/WaterButton";

const { user } = Astro.locals;
const supabase = createClient(Astro.request.headers, Astro.cookies);

const [{ data: prefs }, { data: fields }] =
  user && supabase
    ? await Promise.all([getUserPreferences(supabase, user.id), getFieldsByUser(supabase, user.id)])
    : [{ data: null }, { data: [] }];

const hasRegion = Boolean(prefs?.region_id);
const locationRequired = Astro.url.searchParams.get("location") === "required";
const initialCity = prefs ? { cityName: prefs.city_name, latitude: prefs.latitude, longitude: prefs.longitude } : null;

let rainfall7dMmFromDb: number | null = null;
let rainfall7dMmForDisplay: number | null = null;
let rainfallStale = false;
const fieldWateringStatuses: Record<string, WateringStatus> = {};

if (user && supabase && prefs?.region_id) {
  const [
    { data: rainfall7d, rainfallStale: stale, windowDates, todayInTz },
    { data: allPlantings },
    { data: plants },
  ] = await Promise.all([
    getRainfall7dCalendarMm(supabase, prefs.region_id),
    getPlantingsByUser(supabase, user.id),
    getPlants(supabase),
  ]);

  const wateringWindowDates = todayInTz ? [...windowDates, todayInTz] : windowDates;
  const { data: wateringEvents, error: wateringEventsError } =
    wateringWindowDates.length > 0
      ? await getWateringEventsInWindow(supabase, user.id, wateringWindowDates)
      : { data: [], error: null };

  rainfall7dMmFromDb = rainfall7d;
  rainfallStale = stale;

  const rainfall7dMm = rainfall7d !== null && !stale ? rainfall7d : null;
  const wateringRows = wateringEventsError ? [] : (wateringEvents ?? []);
  const totalManualWateringMm = sumAllWateringEventsMm(wateringRows);
  const hasManualWatering = totalManualWateringMm > 0;

  if (rainfall7dMm !== null) {
    rainfall7dMmForDisplay = rainfall7dMm + totalManualWateringMm;
  } else if (hasManualWatering) {
    rainfall7dMmForDisplay = totalManualWateringMm;
  }

  const canEvaluateWatering = (rainfall7dMm !== null || hasManualWatering) && allPlantings && plants;

  if (canEvaluateWatering) {
    const baseRainfallMm = rainfall7dMm ?? 0;
    const plantingsByField = new Map<string, typeof allPlantings>();
    for (const planting of allPlantings) {
      const list = plantingsByField.get(planting.field_id) ?? [];
      list.push(planting);
      plantingsByField.set(planting.field_id, list);
    }

    for (const field of fields ?? []) {
      const fieldPlantings = plantingsByField.get(field.id) ?? [];
      if (fieldPlantings.length === 0) continue;

      const manualWateringMm = aggregateWateringEventsMm(wateringRows, field.id);
      const effectiveRainfallMm = baseRainfallMm + manualWateringMm;
      const statuses = fieldPlantings.map((planting) =>
        evaluatePlantingWatering(planting, plants, effectiveRainfallMm),
      );
      const aggregated = aggregateFieldWatering(statuses);
      if (aggregated) {
        fieldWateringStatuses[field.id] = aggregated;
      }
    }
  }
}
---

<Layout title={pl.dashboard.title}>
  <AppShell title={pl.dashboard.title} activeNav="dashboard">
    {
      !hasRegion ? (
        <div class="mx-auto flex max-w-md flex-col items-center gap-4 py-8 text-center">
          {locationRequired && <p class="text-destructive text-sm">{pl.dashboard.locationRequiredBeforeField}</p>}
          <div class="border-border bg-card space-y-4 rounded-xl border p-8 shadow-sm">
            <p class="text-muted-foreground text-sm">{pl.dashboard.locationNotSet}</p>
            <a
              href="/dashboard/settings"
              class="bg-primary text-primary-foreground hover:bg-primary/90 inline-flex min-h-11 items-center rounded-lg px-4 py-2 text-sm font-medium transition-colors"
            >
              {pl.dashboard.goToSettings}
            </a>
          </div>
        </div>
      ) : (
        <div class="grid grid-cols-1 gap-6 lg:grid-cols-[1fr_auto]">
          <div class="space-y-4">
            <div class="flex items-center justify-between gap-2">
              <h2 class="text-foreground text-lg font-semibold">{pl.dashboard.myFields}</h2>
              <div class="flex items-center gap-2">
                <WaterButton client:visible fieldId={null} label={pl.watering.waterAllButton} />
                <a
                  href="/dashboard/fields/new"
                  class="bg-primary text-primary-foreground hover:bg-primary/90 inline-flex min-h-11 items-center rounded-lg px-3 py-2 text-sm font-medium transition-colors"
                >
                  + {pl.dashboard.newField}
                </a>
              </div>
            </div>

            {fields && fields.length > 0 ? (
              <ul class="space-y-2">
                {fields.map((field) => (
                  <li>
                    <FieldListItem
                      client:visible
                      fieldId={field.id}
                      name={field.name}
                      sizeLabel={pl.dashboard.rowsCols(field.rows, field.cols)}
                      wateringStatus={fieldWateringStatuses[field.id] ?? null}
                    />
                  </li>
                ))}
              </ul>
            ) : (
              <div class="border-border bg-card text-muted-foreground rounded-xl border p-8 text-center shadow-sm">
                <p>{pl.dashboard.noFields}</p>
                <a href="/dashboard/fields/new" class="text-primary mt-2 inline-block text-sm hover:underline">
                  {pl.dashboard.createFirstField}
                </a>
              </div>
            )}
          </div>

          <div class="flex items-start justify-center lg:justify-start">
            <WeatherWidget
              initialCity={initialCity}
              editable={false}
              rainfall7dMmFromDb={rainfall7dMmForDisplay ?? rainfall7dMmFromDb}
              rainfall7dLabel={pl.weather.moisture7d}
              rainfallStale={rainfallStale}
              client:load
            />
          </div>
        </div>
      )
    }
  </AppShell>
</Layout>
