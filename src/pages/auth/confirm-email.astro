---
import Layout from "@/layouts/Layout.astro";
import { pl } from "@/lib/copy/pl";

const isAutoConfirmed = import.meta.env.DEV;

const content = isAutoConfirmed
  ? {
      emoji: "✅",
      heading: pl.auth.confirmEmailDevTitle,
      description: pl.auth.confirmEmailDevMessage,
      linkText: pl.auth.confirmEmailDevLink,
    }
  : {
      emoji: "📧",
      heading: pl.auth.confirmEmailTitle,
      description: pl.auth.confirmEmailMessage,
      linkText: pl.auth.confirmEmailBack,
    };
---

<Layout title={content.heading}>
  <div class="bg-background flex min-h-screen items-center justify-center p-4">
    <div class="border-border bg-card w-full max-w-sm rounded-xl border p-8 text-center shadow-sm">
      <div class="mb-4 text-5xl">{content.emoji}</div>
      <h1 class="text-foreground mb-3 text-2xl font-bold">
        {content.heading}
      </h1>
      <p class="text-muted-foreground mb-6">{content.description}</p>
      <a href="/auth/signin" class="text-primary text-sm hover:underline">
        {content.linkText}
      </a>
    </div>
  </div>
</Layout>
